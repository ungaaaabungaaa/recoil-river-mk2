# Public client configuration. These values are safe to expose.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
WXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
WXT_PUBLIC_WEB_URL=https://your-recoil-river.example

# Set these on the Convex deployment only. Never prefix them with NEXT_PUBLIC_ or WXT_PUBLIC_.
FIRECRAWL_API_KEY=replace-in-convex-dashboard
OPENROUTER_API_KEY=replace-in-convex-dashboard
OPENROUTER_SUMMARY_MODEL=openai/gpt-5-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
